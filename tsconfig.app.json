{
  // defines paths to apply this tsconfig to
  "include": ["src", "node_modules_type_overrides"],
  "compilerOptions": {
    // A file for storing compilation information to build faster
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    // Output JS version, newer used features might be downleveled to run on older JS version
    "target": "ESNext",
    // Define which built-in environment APIs global types are pulled in.
    "lib": ["ESNext", "DOM"],
    // Define which external libraries' global types are pulled in.
    "types": [], // default value
    // Sets the module system for the program, influences 'import' / 'export' translation into JS
    "module": "ESNext",
    // Skip any errors in d.ts files (including node_modules), invalid types treated as 'any'
    "skipLibCheck": true,
    
    /* Bundler mode */
    // Use bundler-specific features when resolving imports. Vite is bundler
    "moduleResolution": "bundler",
    // Tells tsc to not emit any output files.
    // Output files will be generated by bundler in later build stage.
    // Allows to use .ts, .mts, .tsx , ... extensions in imports
    "allowImportingTsExtensions": true,
    // Enforces path in import to be fully equal to path in filesystem
    "forceConsistentCasingInFileNames": true,
    // Allows import .json file as module
    "resolveJsonModule": true,
    // Enforces to use 'import type ...' / 'export type ...' for types
    "verbatimModuleSyntax": true,
    // Treat all files as modules
    "moduleDetection": "force",
    "noEmit": true,
    // Controls how JSX constructs are transformed during the compilation process
    "jsx": "react-jsx",
    
    /* Editor Support */
    // Allow TS to allocate any amount of memory
    "disableSizeLimit": true,
    
    /* Linting */
    "strict": true,
    // It is useless when using multiple static factory methods.
    "strictPropertyInitialization": false,
    "erasableSyntaxOnly": false,
    // Checks module existence even if you don't import any values from it
    "noUncheckedSideEffectImports": true, // default value
    "allowUnreachableCode": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false,
    "noImplicitOverride": true,
    // '?' means absence of property but not 'undefined'
    "exactOptionalPropertyTypes": true,
    // Disallow for indexed type to write 'obj.prop' in addition to 'obj['prop']'
    "noPropertyAccessFromIndexSignature": false,
    // Add 'undefined' when get prop of indexed type
    "noUncheckedIndexedAccess": false,
    
    /* Path aliases */
    // Aliases for ts compiler.
    // Aliases (except "*" alias) must be duplicated in vite.config.ts
    // to build paths for workers & css.
    "paths": {
      "*": [
        "./src/*",
        "./node_modules_type_overrides/*"
      ],
      
      "src/*": ["./src/*"],
      
      "@app/*": ["./src/app/*"],
      "@entities/*": ["./src/entities/*"],
      "@features/*": ["./src/features/*"],
      "@screens/*": ["./src/screens/*"],
      "@widgets/*": ["./src/widgets/*"],
      
      "@assets/*": ["./src/shared/assets/*"],
      "@lib/*": ["./src/shared/lib/*"],
      "@utils/*": ["./src/shared/utils/*"],
    }
  }
}
