
# Docker user & version (not used in dev & stg deploy)
DOCKER_IMAGE_NAMESPACE=
DOCKER_IMAGE_VERSION=

# 'outer requests' go to 'proxy'
PROXY_HOST=tetris.stg.rraindev
PROXY_PORT=40200
PROXY_CERT_CRT=./tetris.stg.rraindev.pem.crt
PROXY_CERT_KEY=./tetris.stg.rraindev.pem.key

# 'proxy' go to 'react'
REACT_PORT=40209

# App deploy config
APP_LOCALE=en-US
APP_THEME=dark
