
# Docker user & version (not used in dev & stg deploy)
DOCKER_IMAGE_NAMESPACE=
DOCKER_IMAGE_VERSION=

# 'outer requests' go to 'proxy'
PROXY_HOST=tetris.dev.rraindev
PROXY_PORT=40100
PROXY_CERT_CRT=./tetris.dev.rraindev.pem.crt
PROXY_CERT_KEY=./tetris.dev.rraindev.pem.key

# 'proxy' go to 'react'
REACT_PORT=40109

# App deploy config
APP_LOCALE=en-US
APP_THEME=dark
